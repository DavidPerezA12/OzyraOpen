# ============================================================================
# VARIABLES DE ENTORNO - PLANTILLA SEGURA
# ============================================================================
# 
# IMPORTANTE: 
# - Copia este archivo como .env.local para desarrollo
# - NUNCA commitees archivos .env con valores reales
# - Las variables VITE_ son públicas y visibles en el frontend
#
# ============================================================================

# ============================================================================
# VARIABLES FRONTEND (Visibles en el navegador)
# ============================================================================
# Todo valor VITE_ queda expuesto al cliente. Deja vacías las claves que no quieras publicar.

# OpenRouter
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
VITE_OPENROUTER_SITE_URL=http://localhost:5173
VITE_OPENROUTER_APP_TITLE=Ozyra Open

# Proveedores opcionales de búsqueda web directa
# Nota: estas claves también quedan visibles en el navegador.
VITE_TAVILY_API_KEY=
VITE_BRAVE_SEARCH_API_KEY=

# URL del sitio
VITE_SITE_URL=http://localhost:5173

# Configuración de desarrollo
VITE_DEBUG=false
